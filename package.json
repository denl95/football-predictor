		"bcryptjs": "^3.0.3",
		"next": "16.2.3",
		"next-auth": "^5.0.0-beta.30",
		"pg": "^8.20.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@tailwindcss/postcss": "^4",
		"@types/bcryptjs": "^3.0.0",
		"@types/node": "^20",
		"@types/pg": "^8.20.0",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"dotenv": "^17.4.1",
		"prisma": "^7.7.0",
